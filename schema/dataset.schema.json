{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Open Silicon Triage — Run Record",
  "description": "Schema for a single chip design run record in the Open Silicon Triage corpus",
  "type": "object",
  "required": ["schemaVersion", "recordId", "project", "variant", "pdk", "tool", "metrics", "outcome", "observedAt"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "open-silicon-triage.corpus.v1"
    },
    "recordId": {
      "type": "string",
      "description": "Unique identifier for this record"
    },
    "project": {
      "type": "string",
      "description": "Project or organization name"
    },
    "variant": {
      "type": "string",
      "description": "Design variant identifier"
    },
    "pdk": {
      "type": "string",
      "description": "Process Design Kit used (e.g. sky130A, gf180mcuD)"
    },
    "tool": {
      "type": "string",
      "description": "EDA tool and version (e.g. OpenLane 2.1.0)"
    },
    "metrics": {
      "type": "object",
      "required": ["hpwlUm", "averageSinkWireLengthUm", "setupWnsNs", "setupViolations", "holdViolations", "antennaViolations"],
      "properties": {
        "hpwlUm": {
          "type": "number",
          "description": "Half-Perimeter Wire Length in micrometers"
        },
        "averageSinkWireLengthUm": {
          "type": "number",
          "description": "Average sink (capacitive load) wire length in micrometers"
        },
        "setupWnsNs": {
          "type": "number",
          "description": "Worst Negative Slack for setup timing in nanoseconds (negative = violation)"
        },
        "setupViolations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of setup timing violations"
        },
        "holdViolations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of hold timing violations"
        },
        "antennaViolations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of antenna rule violations"
        },
        "maxCapViolations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of max capacitance violations"
        },
        "maxSlewViolations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of max slew violations"
        }
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["negative_evidence", "strategic_progress", "promoted_winner"],
      "description": "Observed outcome of the run"
    },
    "observedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the run was observed"
    },
    "contributor": {
      "type": "string",
      "description": "Contributor identifier (use 'anonymous' if desired)"
    }
  }
}
